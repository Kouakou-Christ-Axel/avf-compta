  "productName": "avf-compta",
  "version": "0.1.0",
  "identifier": "com.kouax.avf-compta",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
